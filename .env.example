# Code Aqua ERP Solutions — Frontend Configuration
# Update NEXT_PUBLIC_API_URL to point to your backend API server
NEXT_PUBLIC_API_URL=http://localhost:9003/api

# Twilio configuration (replace placeholders with your actual credentials)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_MESSAGING_SERVICE_SID=your_twilio_messaging_service_sid_here
